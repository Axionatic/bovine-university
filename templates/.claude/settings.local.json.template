{
  "permissions": {
    "deny": [
      "Bash(sudo:*)", "Bash(su :*)",
      "Bash(chmod +s:*)", "Bash(chmod u+s:*)", "Bash(chown:*)",
      "Bash(eval:*)", "Bash(exec:*)",
      "Bash(bash -c:*)", "Bash(sh -c:*)",
      "Bash(curl * | bash:*)", "Bash(curl * | sh:*)",
      "Bash(wget * | bash:*)", "Bash(wget * | sh:*)",
      "Bash(git push --force origin main:*)",
      "Bash(git push --force origin master:*)",
      "Bash(git push -f origin main:*)",
      "Bash(git push -f origin master:*)",
      "Bash(git push --force-with-lease origin main:*)",
      "Bash(git push --force-with-lease origin master:*)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": []
    },
    "filesystem": {
      "denyRead": ["~/.ssh", "~/.aws", "~/.gnupg", "~/.config/gcloud"],
      "denyWrite": [".claude/settings*", ".claude/RALPH.md", ".env", ".env.*", "*.pem", "*.key"]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/ralph-preflight.sh\""
          }
        ]
      }
    ]
  }
}
